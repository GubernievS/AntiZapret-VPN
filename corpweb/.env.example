# Database
DB_USER=corpweb
DB_PASSWORD=change_me_in_production
DB_NAME=corpweb_db
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# Security
SECRET_KEY=change_me_to_random_string_64_chars_minimum
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_DOMAIN=yourcompany.com

# Application URLs
FRONTEND_URL=https://vpn-admin.yourcompany.com
BACKEND_URL=https://vpn-admin.yourcompany.com/api
CORS_ORIGINS=https://vpn-admin.yourcompany.com

# Paths
VPN_CLIENT_SCRIPT=/root/antizapret/client.sh
VPN_CLIENT_DIR=/root/antizapret/client

# Logging
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
