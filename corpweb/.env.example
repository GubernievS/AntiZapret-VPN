# Database
DATABASE_URL=postgresql://corpweb:change_me@localhost:5432/corpweb_db

# Security
SECRET_KEY=change_me_to_random_string_64_chars_minimum
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Google OAuth
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_DOMAIN=yourcompany.com

# Application URLs
FRONTEND_URL=https://vpn-admin.yourcompany.com
BACKEND_URL=https://vpn-admin.yourcompany.com/api
CORS_ORIGINS=https://vpn-admin.yourcompany.com

# VPN Paths
VPN_CLIENT_SCRIPT=/root/antizapret/client.sh
VPN_CLIENT_DIR=/root/antizapret/client

# Monitoring
MONITORING_UPDATE_INTERVAL=30
OPENVPN_STATUS_LOG_DIR=/etc/openvpn/server/logs

# Logging
LOG_LEVEL=INFO

# Rate Limiting (optional, default 60)
# RATE_LIMIT_PER_MINUTE=60
